{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "lotm:dawn_light_ray",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "curves": {
      "variable.fade_in_out": {
        "type": "bezier",
        "nodes": [0.0, 1.0, 1.0, 0.0]
      }
    },
    "components": {
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_once": {
        "active_time": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0, 0],
        "direction": [0, -1, 0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "1.5 + math.random(0, 0.5)"
      },
      "minecraft:particle_initial_speed": 0,
      "minecraft:particle_motion_parametric": {
        "relative_position": [
          "0",
          "variable.particle_age * -8",
          "0"
        ],
        "direction": [0, -1, 0]
      },
      "minecraft:particle_appearance_billboard": {
        "size": ["1.2 - variable.particle_age * 0.3", "8.0"],
        "facing_camera_type": "rotate_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [0, 56],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": {
            "0.0":  [1.0, 0.98, 0.75, 0.0],
            "0.1":  [1.0, 0.98, 0.80, 0.9],
            "0.5":  [1.0, 0.95, 0.65, 0.7],
            "0.85": [1.0, 0.88, 0.45, 0.4],
            "1.0":  [1.0, 0.80, 0.20, 0.0]
          },
          "interpolant": "variable.particle_age / variable.particle_lifetime"
        }
      }
    }
  }
}
