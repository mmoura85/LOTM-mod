{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "lotm:dawn_ground_glow",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "curves": {
      "variable.radius": {
        "type": "linear",
        "nodes": [0.0, 1.0],
        "input": "variable.particle_age / variable.particle_lifetime"
      }
    },
    "components": {
      "minecraft:emitter_rate_steady": {
        "spawn_rate": 24,
        "max_particles": 80
      },
      "minecraft:emitter_lifetime_looping": {
        "active_time": 1000,
        "sleep_time": 0
      },
      "minecraft:emitter_shape_disc": {
        "radius": 1.5,
        "plane_normal": [0, 1, 0],
        "direction": "outwards"
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "0.8 + math.random(0, 0.4)"
      },
      "minecraft:particle_initial_speed": "1.5 + math.random(0, 1.0)",
      "minecraft:particle_motion_dynamic": {
        "linear_drag_coefficient": 2.0
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.08 + (variable.particle_age / variable.particle_lifetime) * 0.04",
          "0.08 + (variable.particle_age / variable.particle_lifetime) * 0.04"
        ],
        "facing_camera_type": "lookat_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [56, 8],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": {
            "0.0":  [1.0, 0.96, 0.60, 0.0],
            "0.15": [1.0, 0.96, 0.60, 1.0],
            "0.7":  [1.0, 0.80, 0.30, 0.6],
            "1.0":  [1.0, 0.70, 0.10, 0.0]
          },
          "interpolant": "variable.particle_age / variable.particle_lifetime"
        }
      }
    }
  }
}
