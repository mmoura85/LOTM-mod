{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.lotm_ghost": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "flying": "query.modified_move_speed > 0.01"
            }
          ]
        },
        "flying": {
          "animations": [
            "fly"
          ],
          "transitions": [
            {
              "idle": "query.modified_move_speed <= 0.01"
            }
          ]
        }
      }
    }
  }
}